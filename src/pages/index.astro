---
import '../styles/global.css';
import { Github, Mail, Terminal, ExternalLink, Code2, Cpu } from 'lucide-react';

const response = await fetch('https://api.github.com/users/sepc1012/repos?sort=updated');
const allRepos = await response.json();
const projects = allRepos.filter(repo => repo.name !== 'sepc1012.github.io' && repo.description).slice(0, 3);
---

<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sebastian | Dev</title>
</head>
<body class="bg-[#020617] text-slate-200 selection:bg-blue-500/30 min-h-screen p-6 md:p-12 font-sans">
    
    <main class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div class="md:col-span-2 bg-slate-900/40 border border-slate-800 rounded-2xl p-8 flex flex-col justify-between hover:border-blue-500/50 transition-colors">
            <div>
                <div class="flex items-center gap-2 text-blue-400 mb-4">
                    <Terminal size={18} />
                    <span class="font-mono text-sm tracking-widest uppercase">Junior Developer</span>
                </div>
                <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-4">
                    Sebastián <span class="text-blue-500">.</span>
                </h1>
                <p class="text-slate-400 text-lg max-w-md leading-relaxed">
                    Especializado en <span class="text-slate-200">Java y Kotlin</span>. 
                    Enfocado en crear soluciones eficientes desde Lima, Perú.
                </p>
            </div>
            <div class="mt-8 flex gap-4">
                <a href="https://github.com/sepc1012" class="p-3 bg-slate-800 rounded-full hover:bg-blue-600 transition-all text-white"><Github size={20}/></a>
                <a href="mailto:pizarrochauca.sebastian" class="p-3 bg-slate-800 rounded-full hover:bg-blue-600 transition-all text-white"><Mail size={20}/></a>
            </div>
        </div>

        <div class="bg-blue-900/20 border border-blue-800/30 rounded-2xl p-8 flex flex-col justify-center gap-4">
            <h3 class="text-blue-400 font-bold flex items-center gap-2 uppercase text-xs tracking-[0.2em]">Stack</h3>
            <ul class="space-y-3 font-mono text-sm">
                <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div> Java / Spring Boot</li>
                <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div> Kotlin / Android</li>
                <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div> Python Automation</li>
                <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div> Arch Linux / CachyOS</li>
            </ul>
        </div>

        <div class="md:col-span-3">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-3">
                <span class="w-8 h-[1px] bg-blue-500"></span> Proyectos Destacados
            </h2>
            <div class="flex md:grid md:grid-cols-3 gap-6 overflow-x-auto snap-x snap-mandatory pb-4 md:pb-0 scrollbar-hide">
                {projects.map(repo => (
                    <div class="min-w-[85%] md:min-w-full snap-center bg-slate-900/40 border border-slate-800 p-6 rounded-2xl flex flex-col justify-between group hover:bg-slate-800/60 transition-all">
                        <div>
                            <div class="flex justify-between items-center mb-4">
                                <Code2 size={20} class="text-blue-500" />
                                <a href={repo.html_url} target="_blank" class="text-slate-500 hover:text-white transition-colors"><ExternalLink size={18}/></a>
                            </div>
                            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">{repo.name}</h3>
                            <p class="text-sm text-slate-400 line-clamp-3 mb-6 font-light leading-relaxed">{repo.description}</p>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest text-blue-500/80 uppercase">{repo.language || 'Code'}</span>
                    </div>
                ))}
            </div>
        </div>

        <div class="md:col-span-3 bg-gradient-to-r from-blue-900/40 to-slate-900/40 border border-blue-800/40 rounded-2xl p-8 flex flex-col md:flex-row items-center justify-between gap-6 overflow-hidden relative">
            <div class="relative z-10 text-center md:text-left">
                <span class="text-blue-500 font-mono text-xs font-bold uppercase tracking-widest">Main Project</span>
                <h3 class="text-3xl font-black text-white mt-1">ServiCore</h3>
                <p class="text-slate-400 mt-2 max-w-md">Sistema integral de gestión para "A Su Servicio". Automatización de inventario y flujos de caja.</p>
            </div>
            <div class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-full font-bold transition-all cursor-default relative z-10 shadow-lg shadow-blue-900/20">
                En Desarrollo
            </div>
            <Cpu class="absolute right-[-20px] bottom-[-20px] text-blue-500/10 w-40 h-40 rotate-12" />
        </div>

    </main>

    <footer class="max-w-5xl mx-auto mt-16 pt-8 border-t border-slate-900 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500 text-xs font-mono uppercase tracking-widest">
        <p>© 2026 Sebastian Pizarro</p>
        <p>Lima, Perú • {new Date().getFullYear()}</p>
    </footer>
</body>
</html>

<style is:global>
    /* Ocultar scrollbar pero permitir scroll en móvil */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    
    html { scroll-behavior: smooth; }
</style>